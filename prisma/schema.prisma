generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ProblemType {
  FUNCTIONAL
  TRADITIONAL
}

enum SubmissionLanguage {
  C
  CPP
  PYTHON
  GO
  RUST
  JAVA
}

enum SubmissionStatus {
  QUEUED
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  JUDGE_ERROR
}

enum JudgeResultStatus {
  PENDING
  PASSED
  FAILED
  ERROR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role     @default(STUDENT)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  submissions  Submission[]
}

model Problem {
  id                      String      @id @default(cuid())
  problemNumber           Int?
  slug                    String      @unique
  title                   String
  statement               String
  topic                   String
  source                  String
  difficulty              Difficulty
  type                    ProblemType
  acceptanceRate          Float?
  functionName            String?
  functionSignature       String?
  traditionalInputFormat  String?
  traditionalOutputFormat String?
  timeLimitMs             Int?
  memoryLimitMb           Int?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  examples                Example[]
  testCases               TestCase[]
  submissions             Submission[]
}

model Example {
  id          String  @id @default(cuid())
  problemId   String
  input       String
  output      String
  explanation String?
  sortOrder   Int
  problem     Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId, sortOrder])
}

model TestCase {
  id             String        @id @default(cuid())
  problemId      String
  input          String
  expectedOutput String
  isSample       Boolean       @default(false)
  sortOrder      Int
  points         Int           @default(1)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  problem        Problem       @relation(fields: [problemId], references: [id], onDelete: Cascade)
  judgeResults   JudgeResult[]

  @@index([problemId, sortOrder])
}

model Submission {
  id          String             @id @default(cuid())
  userId      String
  problemId   String
  language    SubmissionLanguage
  sourceCode  String
  status      SubmissionStatus   @default(QUEUED)
  score       Int                @default(0)
  message     String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem     Problem            @relation(fields: [problemId], references: [id], onDelete: Cascade)
  judgeResults JudgeResult[]

  @@index([userId, createdAt])
  @@index([problemId, createdAt])
}

model JudgeResult {
  id            String            @id @default(cuid())
  submissionId  String
  testCaseId    String
  status        JudgeResultStatus @default(PENDING)
  judge0Token   String?
  judge0StatusId Int?
  stdout        String?
  stderr        String?
  compileOutput String?
  timeSec       Float?
  memoryKb      Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  submission    Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCase      TestCase          @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([submissionId, testCaseId])
  @@index([submissionId])
}