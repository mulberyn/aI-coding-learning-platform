generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ProblemType {
  FUNCTIONAL
  TRADITIONAL
}

enum SubmissionLanguage {
  C
  CPP
  PYTHON
  GO
  RUST
  JAVA
}

enum SubmissionStatus {
  QUEUED
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  JUDGE_ERROR
}

enum JudgeResultStatus {
  PENDING
  PASSED
  FAILED
  ERROR
}

enum ContestType {
  OFFICIAL
  TEAM_PUBLIC
  INDIVIDUAL_PUBLIC
  REPLAY
}

enum ContestFormat {
  OI
  ICPC
  IOI
}

enum ContestStatus {
  NOT_STARTED
  IN_PROGRESS
  ENDED
}

enum ForumBoard {
  SITE
  JOB
  ACADEMIC
  PROBLEM
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role     @default(STUDENT)
  passwordHash String
  aiProvider   String   @default("deepseek")
  aiModel      String   @default("deepseek-chat")
  aiApiKey     String?
  aiWeeklySummary String?
  aiWeeklySummaryUpdatedAt DateTime?
  aiRecommendations String?
  aiRecommendationsUpdatedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  submissions  Submission[]
  apiKeyConfigs ApiKeyConfig[]
  forumPosts   ForumPost[]
  forumComments ForumComment[]
  contestRegistrations ContestRegistration[]
}

model Problem {
  id                      String      @id @default(cuid())
  problemNumber           Int?
  slug                    String      @unique
  title                   String
  statement               String
  topic                   String
  source                  String
  difficulty              Difficulty
  type                    ProblemType
  acceptanceRate          Float?
  functionName            String?
  functionSignature       String?
  traditionalInputFormat  String?
  traditionalOutputFormat String?
  timeLimitMs             Int?
  memoryLimitMb           Int?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  examples                Example[]
  testCases               TestCase[]
  submissions             Submission[]
  forumPosts              ForumPost[]
}

model Example {
  id          String  @id @default(cuid())
  problemId   String
  input       String
  output      String
  explanation String?
  sortOrder   Int
  problem     Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId, sortOrder])
}

model TestCase {
  id             String        @id @default(cuid())
  problemId      String
  input          String
  expectedOutput String
  isSample       Boolean       @default(false)
  sortOrder      Int
  points         Int           @default(1)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  problem        Problem       @relation(fields: [problemId], references: [id], onDelete: Cascade)
  judgeResults   JudgeResult[]

  @@index([problemId, sortOrder])
}

model Submission {
  id          String             @id @default(cuid())
  userId      String
  problemId   String
  language    SubmissionLanguage
  sourceCode  String
  status      SubmissionStatus   @default(QUEUED)
  score       Int                @default(0)
  message     String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem     Problem            @relation(fields: [problemId], references: [id], onDelete: Cascade)
  judgeResults JudgeResult[]

  @@index([userId, createdAt])
  @@index([problemId, createdAt])
}

model JudgeResult {
  id            String            @id @default(cuid())
  submissionId  String
  testCaseId    String
  status        JudgeResultStatus @default(PENDING)
  judge0Token   String?
  judge0StatusId Int?
  stdout        String?
  stderr        String?
  compileOutput String?
  timeSec       Float?
  memoryKb      Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  submission    Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCase      TestCase          @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([submissionId, testCaseId])
  @@index([submissionId])
}

model ApiKeyConfig {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // "deepseek", "qwen", etc
  name      String   // User-friendly name like "Deepseek-主", "Qwen-测试"
  model     String   // Model name for this provider
  apiKey    String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, provider, name])
}

model Contest {
  id          String        @id @default(cuid())
  title       String
  description String?
  type        ContestType
  format      ContestFormat
  status      ContestStatus
  startTime   DateTime
  endTime     DateTime
  duration    Int           // Duration in minutes
  participantCount Int       @default(0)
  announcement String?       // Markdown format announcement/rules
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  problems    ContestProblem[]
  rankings    ContestRanking[]
  registrations ContestRegistration[]
}

model ContestProblem {
  id          String   @id @default(cuid())
  contestId   String
  problemId   String   // Reference to Problem.id
  number      Int      // Problem number in contest (1, 2, 3, ...)
  fullScore   Int      @default(100)
  createdAt   DateTime @default(now())
  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
  @@unique([contestId, number])
}

model ContestRanking {
  id          String   @id @default(cuid())
  contestId   String
  rank        Int
  userId      String
  username    String
  totalScore  Int      @default(0)
  penalty     Int      @default(0)
  details     String   // JSON string storing submission details
  createdAt   DateTime @default(now())
  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
  @@unique([contestId, rank])
}

model ContestRegistration {
  id         String   @id @default(cuid())
  contestId  String
  userId     String
  createdAt  DateTime @default(now())
  contest    Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contestId])
  @@index([userId])
  @@unique([contestId, userId])
}

model ForumPost {
  id         String       @id @default(cuid())
  title      String
  content    String
  isPinned   Boolean      @default(false)
  board      ForumBoard
  userId     String
  problemId  String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem    Problem?     @relation(fields: [problemId], references: [id], onDelete: SetNull)
  comments   ForumComment[]

  @@index([board, createdAt])
  @@index([problemId, createdAt])
  @@index([isPinned, createdAt])
  @@index([userId, createdAt])
}

model ForumComment {
  id         String    @id @default(cuid())
  content    String
  postId     String
  userId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  post       ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}